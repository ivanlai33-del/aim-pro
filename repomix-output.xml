    activeColor: string;
    badge?: string;
}
function SidebarLink({ href, icon, label, isActive, isCollapsed, activeColor, badge }: SidebarLinkProps) {
    return (
        <Link
            href={href}
            className={cn(
                "group flex items-center rounded-2xl transition-all relative",
                isCollapsed ? "h-12 w-12 justify-center mx-auto" : "px-5 h-[64px] w-full",
                isActive
                    ? `${activeColor} text-white shadow-xl ring-4 ring-black/10`
                    : 'text-slate-400 hover:bg-white/5 hover:text-white'
            )}
        >
            <div className={cn(
                "transition-transform group-hover:scale-110",
                isActive ? "text-white" : "text-slate-500 group-hover:text-slate-300"
            )}>
                {icon}
            </div>
            {!isCollapsed ? (
                <>
                    <span className="ml-4 text-base font-black whitespace-nowrap animate-in fade-in slide-in-from-left-2 duration-300">{label}</span>
                    {badge && (
                        <span className={cn(
                            "ml-auto text-[10px] px-2 py-1 rounded-full font-black tracking-widest leading-none",
                            isActive ? "bg-white/20 text-white" : "bg-emerald-400/10 text-emerald-400"
                        )}>
                            {badge}
                        </span>
                    )}
                </>
            ) : (
                <div className="absolute left-full ml-4 px-2 py-1.5 bg-slate-800 text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none z-[100] shadow-2xl border border-white/10 transition-opacity">
                    {label}
                </div>
            )}
        </Link>
    );
}
</file>

