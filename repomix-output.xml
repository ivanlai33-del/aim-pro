export async function fetchAIResponse(projectData: ProjectData, apiKey?: string, customPrompts?: Record<string, string>): Promise<AIResponse> {
    // Find matching module from BUSINESS_MODULES
    const matchedModule = Object.values(BUSINESS_MODULES).find(module =>
        module.projectTypes?.some(pt => pt.id === projectData.projectType)
    );
    // Legacy fallback mapping
    const industryId = Object.keys(INDUSTRY_PROMPTS).find(key => {
        const t = projectData.projectType;
        if (t === 'web' || t === 'landing' || t === 'app') return key === 'web';
        if (t === 'branding' || t === 'print' || t === 'packaging') return key === 'graphic';
        if (t === 'video_prod' || t === 'animation' || t === 'shorts') return key === 'video';
        if (t === 'home' || t === 'commercial' || t === 'office') return key === 'renovation';
        if (t === 'social' || t === 'content') return key === 'marketing';
        if (t === 'ads_meta' || t === 'ads_google') return key === 'ads';
        if (t === 'seo_audit' || t === 'content_strategy') return key === 'seo';
        if (t === 'wedding' || t === 'corporate' || t === 'party') return key === 'event';
        if (t === 'expo' || t === 'special') return key === 'exhibition';
        if (t === 'dc_setup' || t === 'dc_art' || t === 'dc_motion') return key === 'discord';
        return false;
    });
    if (!apiKey) {
        // Simulate network delay
        await new Promise((resolve) => setTimeout(resolve, 2000));
        return { content: getMockWebResponse(projectData) };
    }
    try {
        const genAI = new GoogleGenerativeAI(apiKey);
        let systemPrompt = INDUSTRY_PROMPTS.web; // Default
        // 1. Try to find from BUSINESS_MODULES (Preferred)
        if (matchedModule) {
            systemPrompt = `${matchedModule.corePrompt}\n\n${DEFAULT_OUTPUT_FORMAT}`;
        }
        // 2. Fallback to legacy INDUSTRY_PROMPTS
        else if (industryId && INDUSTRY_PROMPTS[industryId]) {
            systemPrompt = INDUSTRY_PROMPTS[industryId];
        } else {
            // Fallback logic 
            if (['home', 'commercial'].includes(projectData.projectType)) systemPrompt = INDUSTRY_PROMPTS.renovation;
            else if (['packaging', 'branding'].includes(projectData.projectType)) systemPrompt = INDUSTRY_PROMPTS.graphic;
            else if (['social', 'ads'].includes(projectData.projectType)) systemPrompt = INDUSTRY_PROMPTS.marketing;
            else if (['wedding', 'corporate'].includes(projectData.projectType)) systemPrompt = INDUSTRY_PROMPTS.event;
        }
        // Custom override (User Prompt Layer)
        // If matchedModule exists, we use its ID as key
        const moduleKey = matchedModule ? matchedModule.id : industryId;
        if (customPrompts && moduleKey && customPrompts[moduleKey]) {
            // User custom prompt overrides system prompt
            // But we should probably keep the output format if the user didn't include it?
            // Usually user custom prompt replaces the "Persona" part. 
            // For now, let's assume user prompt is the full system instruction.
            systemPrompt = customPrompts[moduleKey];
        }
        // Ensure Output Format is present if using custom prompt? 
        // No, let user control it.
        // Common User Prompt Construction
        // 3. Format Custom Fields for AI context
        let customFieldsContext = '';
        if (matchedModule?.formConfig?.customFields) {
            customFieldsContext = matchedModule.formConfig.customFields
                .map(field => {
                    // @ts-ignore
                    const val = projectData[field.name];
                    if (!val || (Array.isArray(val) && val.length === 0)) return null;
                    const displayVal = Array.isArray(val) ? val.join(', ') : val;
                    return `${field.label}: ${displayVal}`;
                })
                .filter(Boolean)
                .join('\n         ');
        }
        const userPrompt = `
         請針對以下專案需求撰寫估價單與規劃報告：
         專案名稱：${projectData.projectName}
         專案描述：${projectData.description}
         ${customFieldsContext ? `補充細節規格：\n         ${customFieldsContext}` : ''}
         製作項目與規格：${projectData.features}
         風格偏好：${projectData.optimizationGoals || '無特殊需求'}
         預算範圍：${projectData.budget || '未定'}
         時程：${projectData.timeline || '未定'}
         客戶產業/類型：${projectData.clientCompany || '未知'}
         請務必依照 System Prompt 中的 Output Format 格式輸出。
         (Language: Traditional Chinese, Taiwan)
         `;
        const model = genAI.getGenerativeModel({
            model: "gemini-2.0-flash",
            systemInstruction: systemPrompt
        });
        const result = await model.generateContent(userPrompt);
        const response = result.response;
        const text = response.text();
        return { content: cleanAIResponse(text) };
    } catch (error) {
        console.error("AI Service Error:", error);
        return {
            content: "",
            error: error instanceof Error ? error.message : "發生未知錯誤"
        };
    }
}
