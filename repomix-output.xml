'use client';
import { useState, useMemo } from 'react';
import { useProject, ExecutionTask, QuotationItem } from '@/context/ProjectContext';
import {
    CheckCircle2,
    Clock,
    AlertCircle,
    User,
    Truck,
    DollarSign,
    Plus,
    ChevronRight,
    PieChart,
    ArrowRightLeft,
    TrendingUp,
    TrendingDown,
    Save,
    Activity,
    Layout,
    Briefcase,
    Trash2,
    Play,
    Pause,
    History
} from 'lucide-react';
import { cn, generateId } from '@/lib/utils';
import { toast } from 'sonner';
import { ProgressBar } from '@/components/ui/ProgressBar';
import ManualTimerModal from './ManualTimerModal';
export default function ExecutionManager() {
    const { activeProject, updateProjectExecution } = useProject();
    // UI States
    const [showFlow, setShowFlow] = useState(false);
    const [showDistribution, setShowDistribution] = useState(false);
    const [activeTimerTaskId, setActiveTimerTaskId] = useState<string | null>(null);
    const [timerStartTime, setTimerStartTime] = useState<number | null>(null);
    const [manualTimerTask, setManualTimerTask] = useState<{ id: string, name: string } | null>(null);
    if (!activeProject) return null;
    const tasks = activeProject.executionTasks || [];
    const quoteItems = activeProject.quotationItems || [];
    // --- Calculations ---
    const totalRevenue = useMemo(() =>
        quoteItems.reduce((sum, item) => sum + (item.unitPrice * item.quantity), 0)
        , [quoteItems]);
    const totalOutsourcedCost = useMemo(() =>
        tasks.filter(t => t.type === 'outsourced' || t.type === 'external').reduce((sum, t) => sum + t.cost, 0)
        , [tasks]);
    const totalDepositsPaid = useMemo(() =>
        tasks.filter(t => t.type === 'outsourced' || t.type === 'external').reduce((sum, t) => sum + t.depositPaid, 0)
        , [tasks]);
    // --- Tax Calculations (Post-tax Pocket Money) ---
    // 1. Outsourced (Invoice): Can deduct 5% VAT (Assuming cost includes tax)
    // 2. External (Labor): Company part of 2nd Gen NHI 2.11%
    const postTaxCosts = useMemo(() => {
        return tasks.reduce((sum, t) => {
            if (t.type === 'outsourced') {
                return sum + (t.cost / 1.05); // Deduct the 5% VAT portion from cost
            } else if (t.type === 'external') {
                return sum + (t.cost * 1.0211); // Add the extra NHI cost
            }
            return sum;
        }, 0);
    }, [tasks]);
    const estimatedNetProfit = totalRevenue - totalOutsourcedCost;
    const realPocketProfit = totalRevenue - postTaxCosts;
    const profitMargin = totalRevenue > 0 ? (estimatedNetProfit / totalRevenue) * 100 : 0;
    const pocketMargin = totalRevenue > 0 ? (realPocketProfit / totalRevenue) * 100 : 0;
    // --- Distribution Summary Data ---
    const staffSummary = useMemo(() => {
        const summary: Record<string, { internal: number, outsourced: number, completed: number, total: number }> = {};
        tasks.forEach(t => {
            const key = t.assignee || '未指派';
            if (!summary[key]) summary[key] = { internal: 0, outsourced: 0, completed: 0, total: 0 };
            if (t.type === 'internal') summary[key].internal++;
            else if (t.type === 'outsourced' || t.type === 'external') summary[key].outsourced++;
            if (t.status === 'completed' || t.status === 'verified') summary[key].completed++;
            summary[key].total++;
        });
        return summary;
    }, [tasks]);
    // --- Handlers ---
    const handleAddTask = (quoteItemId?: string) => {
        const newTask: ExecutionTask = {
            id: generateId(),
            quoteItemId,
            name: quoteItemId ? `細部執行: ${quoteItems.find(i => i.id === quoteItemId)?.description || ''}` : '新核定任務',
            description: '',
            type: 'internal',
            assignee: '',
            status: 'pending',
            cost: 0,
            depositPaid: 0,
        };
        updateProjectExecution(activeProject.id, [...tasks, newTask]);
        if (showDistribution) setShowDistribution(false);
    };
    const handleUpdateTask = (id: string, updates: Partial<ExecutionTask>) => {
        const newTasks = tasks.map(t => t.id === id ? { ...t, ...updates } : t);
        updateProjectExecution(activeProject.id, newTasks);
    };
    const handleDeleteTask = (id: string) => {
        const newTasks = tasks.filter(t => t.id !== id);
        updateProjectExecution(activeProject.id, newTasks);
    };
    const handleAddTimeLog = (taskId: string, duration: number, note: string) => {
        const task = tasks.find(t => t.id === taskId);
        if (!task) return;
        const newLog = {
            id: generateId(),
            date: new Date().toISOString(),
            duration,
            note
        };
        const newTask = {
            ...task,
            timeLogs: [...(task.timeLogs || []), newLog]
        };
        handleUpdateTask(taskId, newTask);
        toast.success(`成功紀錄 ${duration} 分鐘工時`);
    };
    const handleDeleteTimeLog = (taskId: string, logId: string) => {
        const task = tasks.find(t => t.id === taskId);
        if (!task) return;
        const newTask = {
            ...task,
            timeLogs: (task.timeLogs || []).filter(l => l.id !== logId)
        };
        handleUpdateTask(taskId, newTask);
    };
    return (
        <div className="space-y-8 pb-20 font-sans">
            {/* View Mode Toggles */}
            <div className="flex justify-between items-center">
                <div className="flex bg-slate-100/80 p-1.5 rounded-2xl border border-slate-200 shadow-inner">
                    <button
                        onClick={() => { setShowFlow(false); setShowDistribution(false); }}
                        className={cn(
                            "px-8 py-3 rounded-xl text-sm font-black transition-all flex items-center h-12",
                            (!showFlow && !showDistribution)
                                ? "bg-gradient-to-br from-indigo-500 to-violet-600 text-white shadow-[0_8px_20px_-4px_rgba(79,70,229,0.4)]"
                                : "text-slate-500 hover:text-indigo-900 hover:bg-white/50"
                        )}
                    >
                        <Layout className="w-5 h-5 mr-2" />
                        任務清單
                    </button>
                    <button
                        onClick={() => { setShowFlow(true); setShowDistribution(false); }}
                        className={cn(
                            "px-8 py-3 rounded-xl text-sm font-black transition-all flex items-center h-12",
                            (showFlow && !showDistribution)
                                ? "bg-gradient-to-br from-indigo-500 to-violet-600 text-white shadow-[0_8px_20px_-4px_rgba(79,70,229,0.4)]"
                                : "text-slate-500 hover:text-indigo-900 hover:bg-white/50"
                        )}
                    >
                        <ArrowRightLeft className="w-5 h-5 mr-2" />
                        預算流向圖
                    </button>
                    <button
                        onClick={() => { setShowDistribution(true); setShowFlow(false); }}
                        className={cn(
                            "px-8 py-3 rounded-xl text-sm font-black transition-all flex items-center h-12",
                            showDistribution
                                ? "bg-gradient-to-br from-indigo-500 to-violet-600 text-white shadow-[0_8px_20px_-4px_rgba(79,70,229,0.4)]"
                                : "text-slate-500 hover:text-indigo-900 hover:bg-white/50"
                        )}
                    >
                        <Activity className="w-5 h-5 mr-2" />
                        執行分配圖
                    </button>
                </div>
                <div className="text-sm font-black text-slate-500 flex items-center bg-gradient-to-r from-slate-100 to-slate-200 px-5 py-2.5 rounded-2xl border border-slate-300 shadow-sm">
                    <AlertCircle className="w-4 h-4 mr-2 text-slate-400" />
                    PM 專屬視窗
                </div>
            </div>
            {/* 1. Summary Cards */}
            {!showDistribution && (
                <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div className="bg-gradient-to-br from-white to-indigo-50/50 p-8 rounded-3xl shadow-xl shadow-indigo-100 border border-slate-100 flex flex-col justify-between overflow-hidden relative group transition-all hover:shadow-2xl hover:shadow-indigo-200/50 hover:-translate-y-1 cursor-pointer" onClick={() => setShowFlow(true)}>
                        <div className="absolute top-0 right-0 p-6 opacity-[0.03] group-hover:opacity-10 transition-opacity">
                            <DollarSign className="w-24 h-24 text-indigo-900" />
                        </div>
                        <div>
                            <p className="text-xs font-black text-slate-400 uppercase tracking-widest leading-none mb-3">專案總額</p>
                            <h3 className="text-4xl font-black text-slate-800 leading-none tracking-tight">${totalRevenue.toLocaleString()}</h3>
                        </div>
                        <div className="mt-8 flex items-center text-xs">
                            <span className="bg-gradient-to-r from-indigo-500 to-indigo-600 text-white px-4 py-1.5 rounded-xl font-black mr-3 shadow-md shadow-indigo-100">100% REVENUE</span>
                            <span className="text-slate-400 font-black uppercase tracking-wider">點擊查看流向圖</span>
                        </div>
                    </div>
                    <div className="bg-gradient-to-br from-white to-orange-50/50 p-8 rounded-3xl shadow-xl shadow-orange-100 border border-orange-100 flex flex-col justify-between overflow-hidden relative group transition-all hover:shadow-2xl hover:shadow-orange-200/50 hover:-translate-y-1">
                        <div className="absolute top-0 right-0 p-6 opacity-[0.03] group-hover:opacity-10 transition-opacity">
                            <Truck className="w-24 h-24 text-orange-600" />
                        </div>
                        <div>
                            <p className="text-xs font-black text-orange-400 uppercase tracking-widest leading-none mb-3">預計外包成本</p>
                            <h3 className="text-4xl font-black text-orange-600 leading-none tracking-tight">${totalOutsourcedCost.toLocaleString()}</h3>
                        </div>
                        <div className="mt-8 flex justify-between items-center text-xs font-black">
                            <span className="text-orange-600 bg-orange-50 px-3 py-1.5 rounded-lg border border-orange-100">已付: ${totalDepositsPaid.toLocaleString()}</span>
                            <span className="text-slate-400 uppercase tracking-widest">未付: ${(totalOutsourcedCost - totalDepositsPaid).toLocaleString()}</span>
                        </div>
                    </div>
                    <div className={cn(
                        "p-8 rounded-3xl shadow-xl border flex flex-col justify-between overflow-hidden relative group transition-all hover:shadow-2xl hover:-translate-y-1",
                        realPocketProfit < 0
                            ? "bg-gradient-to-br from-rose-50 to-orange-50/50 border-rose-100 shadow-rose-100/50 hover:shadow-rose-200/50"
                            : "bg-gradient-to-br from-emerald-50 to-teal-50/50 border-emerald-100 shadow-emerald-100/50 hover:shadow-emerald-200/50"
                    )}>
                        <div className="absolute top-0 right-0 p-6 opacity-[0.03] group-hover:opacity-10 transition-opacity">
                            <TrendingUp className={cn("w-24 h-24", realPocketProfit < 0 ? "text-rose-600" : "text-emerald-600")} />
                        </div>
                        <div>
                            <p className="text-sm font-black text-slate-400 uppercase tracking-widest leading-none mb-2">預估完稅後收益</p>
                            <h3 className={cn("text-3xl font-black leading-none", realPocketProfit < 0 ? "text-rose-600" : "text-emerald-600")}>
                                ${Math.round(realPocketProfit).toLocaleString()}
                            </h3>
                        </div>
                        <div className="mt-8 flex flex-col gap-2">
                            <ProgressBar
                                value={pocketMargin}
                                max={100}
                                barClassName={realPocketProfit < 0 ? "bg-rose-500" : "bg-emerald-500"}
                            />
                            <div className="flex justify-between items-center text-sm font-black uppercase tracking-tight">
                                <span className="text-slate-500">實質利率: {pocketMargin.toFixed(1)}%</span>
                                {realPocketProfit < 0 && <span className="text-rose-600 animate-pulse font-black">PROFIT WARNING!</span>}
                            </div>
                        </div>
                    </div>
                </div>
            )}
            {/* View Area */}
            {!showFlow && !showDistribution && (
                <div className="bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-200 overflow-hidden">
                    <div className="px-8 py-8 border-b border-slate-100 bg-gradient-to-r from-slate-50 to-white flex justify-between items-center">
