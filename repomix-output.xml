        alerts.push({
            id: 'deadline',
            type: 'error',
            icon: <AlertTriangle className="w-5 h-5" />,
            title: '報稅截止日將至',
            message: `本期營業稅申報僅剩 ${daysUntilDeadline} 天！截止日期為 ${nextDeadlineDate}，請儘速完成。`
        });
    }
    return (
