// Helper to fix Gemini 2.0 Flash's tendency to collapse tables
// Helper to fix Gemini 2.0 Flash's tendency to collapse tables
function cleanAIResponse(text: string): string {
    let cleanText = text;
    // Fix 1: Header to Separator boundary ( | Header | | --- | )
    cleanText = cleanText.replace(/\|\s*\|\s*---/g, '|\n| ---');
    // Fix 2: Separator to Body boundary ( | --- | | Data | )
    cleanText = cleanText.replace(/---\s*\|\s*\|/g, '--- |\n|');
    // Fix 3: Aggressive Row Splitting for concatenated tables
    // Pattern: `| ... | || ... |` -> `| ... |\n| ... |`
    // Convert double pipes (or more) to newline + pipe
    cleanText = cleanText.replace(/\|\s*\|{1,}\s*(?=[^|\n])/g, '|\n|');
    // Fix 4: Force newline before specific key headers if they are stuck
    const keyHeaders = ['項目', '說明', '費用', '階段', '任務', '設計費用', '印刷/製作費', '總預估費用', '工作天數', '備註', 'CIS設計規劃', '品牌識別', 'UI/UX', '第一階段', '第二階段', '第三階段'];
    keyHeaders.forEach(header => {
        // Look for `| header` that is NOT at the start of a line
        const regex = new RegExp(`(?<!^\|\\n)\\|\s*${header}`, 'g');
        cleanText = cleanText.replace(regex, `\n| ${header}`);
    });
    // Fix 5: General "End of Row" heuristic
    // If we see `| <Text> | <Text> |`, and the next char is not a newline, insert one? Too risky.
    // Instead, rely on the specific `||` pattern seen in screenshot.
    cleanText = cleanText.replace(/\|\s*\|(?=\s*[^|\n])/g, '|\n|');
    return cleanText;
}
