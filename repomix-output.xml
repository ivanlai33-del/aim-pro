    id: string;
    name: string;
    description: string;
    icon: string;
    color: string;
    /** 此資料夾下的模組 ID 清單（順序即顯示順序） */
    moduleIds: string[];
    /** 資料夾層級的工作流程（概覽用） */
    workflow: {
        diagram: string;
        milestones: string[];
