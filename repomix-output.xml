                                )}
                                {activeTab === 'plan' && (
                                    <div className="animate-in fade-in zoom-in-95 duration-200 h-full">
                                        <ProjectPlan />
                                    </div>
                                )}
                                {activeTab === 'execution' && (
                                    <div className="animate-in fade-in zoom-in-95 duration-200 h-full">
                                        <ExecutionManager />
                                    </div>
                                )}
                            </div>
                        </div>
                    )}
                </div>
            </div>
            {/* Modals */}
            <DeleteProjectModal
