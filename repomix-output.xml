                                    alert.type === 'error' ? "bg-rose-50 border-rose-100 text-rose-800" :
                                        "bg-indigo-50 border-indigo-100 text-indigo-800"
                            )}
                        >
                            <div className={cn(
                                "p-2 rounded-lg mr-4",
                                alert.type === 'warning' ? "bg-amber-100/50" :
                                    alert.type === 'error' ? "bg-rose-100/50" :
