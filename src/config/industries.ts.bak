// ============================================================
// industries.ts — 商業模組框架
// 架構說明：
//   CategoryFolder  = 資料夾（五大類），僅作分類用途，不可訂閱。
//   BusinessModule  = 獨立商業模組（17 個專業大腦），這是真正的訂閱單位。
//   七大功能模組    = 每個 BusinessModule 的核心內容
// ============================================================

// ============================================================
// SECTION 1: 基礎型別定義
// ============================================================

export interface QuotationItemTemplate {
    description: string;
    unitPrice: number;
    quantity: number;
}

export interface ProjectTypeOption {
    id: string;
    label: string;
    description: string;
    icon?: string;
}

// ============================================================
// SECTION 2: 七大功能模組介面
// ============================================================

/** 模組 1：表單配置 */
export interface FormConfig {
    descriptionPlaceholder: string;
    stylePlaceholder?: string;
    deliverablesPlaceholder?: string;
    /** 多選需求類型（適用設計/行銷類） */
    needsCheckboxes?: Array<{ id: string; label: string }>;
    /** 自訂欄位 */
    customFields?: Array<{
        name: string;
        label: string;
        placeholder: string;
        type?: 'text' | 'textarea' | 'number' | 'select';
        options?: string[];
    }>;
}

/** 模組 2：AI 提示詞配置 */
export interface AIPrompts {
    /** 報告生成 AI 的系統提示詞 */
    reportGeneration: string;
    /** 客戶溝通 AI 的系統提示詞 */
    customerChat: string;
    /** 報價建議 AI 的系統提示詞 */
    quotationSuggestion: string;
}

/** 模組 3：報告模板配置 */
export interface ReportTemplate {
    /** Markdown 報告結構模板 */
    structure: string;
    /** 專業術語對照表 */
    terminology: Record<string, string>;
    /** 分析維度清單 */
    analysisDimensions: string[];
}

/** 模組 4：合約重點配置 */
export interface ContractHighlights {
    mustHaveClauses: string[];
    industrySpecificClauses: string[];
    acceptanceCriteria: string[];
    paymentMilestones: Array<{
        stage: string;
        percentage: number;
        trigger: string;
    }>;
}

/** 模組 5：報價單配置 */
export interface QuotationConfig {
    /** 項目分類名稱（如：功能模組、設計項目、工程項目） */
    categoryName: string;
    /** 計價單位（如：式、坪、小時、月、件） */
    unit: string;
    /** 用詞對照（如：客戶→甲方、廠商→乙方） */
    terminology: Record<string, string>;
    /** 預設報價項目 */
    defaultItems: QuotationItemTemplate[];
}

/** 模組 6：客戶溝通話術配置 */
export interface CommunicationScripts {
    opening: string;
    discoveryQuestions: string[];
    objectionHandling: Record<string, string>;
    closing: string;
}

/** 模組 7：任務執行配置 */
export interface TaskConfig {
    typicalTasks: Array<{
        name: string;
        type: 'internal' | 'outsourced' | 'external';
        duration: string;
        assignee: string;
    }>;
    milestones: Array<{
        label: string;
        order: number;
    }>;
    workflow: {
        diagram: string;
        description: string;
    };
}

// ============================================================
// SECTION 3: 核心介面 — BusinessModule & CategoryFolder
// ============================================================

/**
 * BusinessModule — 獨立商業模組
 * 每個模組是一個完整的「職業工具包」，七大功能模組可逐步完善
 */
export interface BusinessModule {
    // --- 識別資訊 ---
    id: string;
    name: string;
    description: string;
    /** 所屬資料夾 ID (僅供分類顯示，非訂閱單位) */
    categoryId: string;

    // --- 職業 DNA ---
    tagline: string;
    targetUser: string;
    painPoints: string[];

    // --- AI Brain (3-Layer Prompt) ---
    /** 核心職人人格 (IP: L1 Hidden) */
    corePrompt: string;
    /** 使用者自定義模版 (L2 Editable) */
    userPromptTemplate?: string;

    // --- 七大功能模組（可逐步填入） ---
    formConfig?: FormConfig;
    aiPrompts?: AIPrompts;
    reportTemplate?: ReportTemplate;
    contractHighlights?: ContractHighlights;
    quotationConfig?: QuotationConfig;
    communicationScripts?: CommunicationScripts;
    taskConfig?: TaskConfig;

    // --- 報價單預設項目（向後相容） ---
    defaultItems: QuotationItemTemplate[];
    projectTypes?: ProjectTypeOption[];
}

/**
 * CategoryFolder — 資料夾（五大類）
 * ⚠️ 重要：這只是「資料夾分類」，不是訂閱單位。
 * 用戶訂閱的是個別的 BusinessModule (17 種專業大腦)，而非整個資料夾。
 */
export interface CategoryFolder {
    id: string;
    name: string;
    description: string;
    icon: string;
    color: string;
    /** 此資料夾下的模組 ID 清單（順序即顯示順序） */
    moduleIds: string[];
    /** 資料夾層級的工作流程（概覽用） */
    workflow: {
        diagram: string;
        milestones: string[];
    };
}

// 向後相容：IndustryItem = BusinessModule
export type IndustryItem = BusinessModule;
// 向後相容：IndustryCategory 結構
export interface IndustryCategory {
    id: string;
    name: string;
    description: string;
    icon: string;
    items: BusinessModule[];
    workflow: { diagram: string; milestones: string[] };
}

// ============================================================
// SECTION 4: 五大類資料夾定義
// ============================================================

