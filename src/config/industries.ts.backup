
export interface QuotationItemTemplate {
    description: string;
    unitPrice: number;
    quantity: number;
}

export interface ProjectTypeOption {
    id: string; // 'web' | 'design' | string;
    label: string;
    description: string;
    icon?: string;
}

export interface IndustryConfig {
    id: string;
    name: string;
    description: string;
    icon: string;
    defaultPrompt: string;
    defaultItems: QuotationItemTemplate[];
    projectTypes: ProjectTypeOption[];
    workflow: {
        diagram: string;
        milestones: string[];
    };
}

